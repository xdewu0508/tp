@startuml
!include style.puml
skinparam ClassFontColor #000000
skinparam ClassBorderColor #000000
skinparam ClassBackgroundColor #FFFFAA

title After command "undo"

package ModelManager {
    class AB as "<u>addressBook\n:AddressBook</u>" #FFFFAA
    class Prev as "previousAddressBook\n= null" #DDDDDD
    class Redo as "<u>redoAddressBook\n:AddressBook</u>" #FFAAAA
}

AB -[hidden]right-> Prev
Prev -[hidden]right-> Redo

note bottom of AB : Restored to pre-delete state\n(person 5 is back)
note bottom of Redo : Snapshot of post-delete state\n(for redo)
@end
