@startuml
!include style.puml
skinparam ClassFontColor #000000
skinparam ClassBorderColor #000000
skinparam ClassBackgroundColor #FFFFAA

title After command "add n/David"

package ModelManager {
    class AB as "<u>addressBook\n:AddressBook</u>" #FFFFAA
    class Prev as "<u>previousAddressBook\n:AddressBook</u>" #AAFFAA
    class Redo as "redoAddressBook\n= null" #DDDDDD
}

AB -[hidden]right-> Prev
Prev -[hidden]right-> Redo

note bottom of AB : After add\n(David added)
note bottom of Prev : Snapshot before add\n(no David)
note bottom of Redo : Cleared by saveCurrentState()\nRedo no longer available
@end
